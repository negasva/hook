# ── IA (Groq) ────────────────────────────────────────────────────────────────
# Solo para desarrollo local. En Vercel usa GROQ_API_KEY (sin VITE_)
# Obtén tu key gratis en https://console.groq.com
VITE_GROQ_API_KEY=your_groq_api_key_here

# ── Base de datos (Supabase) ──────────────────────────────────────────────────
# Crea tu proyecto en https://supabase.com (gratis)
# Dashboard → Settings → API → Project URL y anon public key
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
